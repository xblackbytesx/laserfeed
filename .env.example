# Copy to .env and fill in real values before running production stack
# (docker compose reads .env automatically)

# Required: base path on the host where Docker data is stored
DOCKER_ROOT=/opt/docker

# Required: random string, minimum 32 characters
CSRF_AUTH_KEY=change-me-to-a-random-32-char-secret

# Required: strong random password for the database
DB_PASSWORD=change-me-to-a-strong-password

# Required: public base URL of this instance (used in feed self-links)
APP_BASE_URL=https://feeds.example.com

# Optional: set to "false" only if running without HTTPS (not recommended for production)
SECURE_COOKIES=true

# Optional: DevTools websocket endpoint of the headless browser used by feeds
# with "Render JavaScript" enabled. Uncomment the laserfeed-chrome service (and
# the chrome-egress network) in the compose file first. Leave unset to disable.
#JS_RENDER_WS_URL=ws://laserfeed-chrome:9222/
