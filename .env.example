# Copy to .env and fill in real values before running production stack
# (docker compose reads .env automatically)

# Required: random string, minimum 32 characters
CSRF_AUTH_KEY=change-me-to-a-random-32-char-secret

# Required: strong random password for the database
DB_PASSWORD=change-me-to-a-strong-password

# Optional: public base URL of this instance (used in feed self-links)
APP_BASE_URL=https://your-domain.example.com

# Optional: set to "false" only if running without HTTPS (not recommended for production)
SECURE_COOKIES=true
